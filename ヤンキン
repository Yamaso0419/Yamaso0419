            background: #111; /* アスファルトの色 */
        }

        #ui {
            position: absolute;
            top: 10px;
            left: 10px;
            font-size: 18px;
            text-shadow: 2px 2px #000;
            pointer-events: none;
        }

        #msg-screen {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.85);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
        }

        h1 { color: #ff3e3e; margin-bottom: 10px; }
        p { margin-bottom: 20px; }
        
        button {
            padding: 12px 30px;
            font-size: 18px;
            background: #ff3e3e;
            color: white;
            border: none;
            cursor: pointer;
            font-weight: bold;
        }

        button:hover { background: #ff0000; }
    </style>
</head>
